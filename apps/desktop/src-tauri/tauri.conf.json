{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live SLIDE CENTER Desktop",
  "version": "0.1.0",
  "identifier": "com.livesoftware.slidecenter.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @slidecenter/web dev -- --mode desktop",
    "beforeBuildCommand": "pnpm --filter @slidecenter/web build:desktop",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist-desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Live SLIDE CENTER",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "Live SLIDE CENTER — versione desktop offline LAN",
    "longDescription": "Live SLIDE CENTER Desktop e' la versione installabile per uso offline su LAN aziendale. Stessa UI della versione cloud (parita' funzionale completa), ma i dati e i file restano sulla rete dell'evento. Il PC server agisce da NAS di raccolta e distribuzione contributi verso i PC sala. Sistema licenze unificato cloud/desktop, aggiornamenti firmati automatici, disinstallazione pulita con preservazione dati opzionale.",
    "copyright": "(C) 2026 Live Software — Andrea Rizzari",
    "publisher": "Live Software",
    "homepage": "https://www.liveworksapp.com",
    "license": "Proprietary",
    "licenseFile": "EULA.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "installer-hooks.nsi",
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["Italian", "English"],
        "compression": "lzma",
        "startMenuFolder": "Live SLIDE CENTER"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/live-software11/live-slide-center/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
