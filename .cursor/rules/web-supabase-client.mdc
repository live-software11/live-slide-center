pairDirectLan({targetBaseUrl, ...}): Promise<PairDirectResult>
pairRevokeLan({targetBaseUrl, ...}): Promise<{ok: boolean, code?: string}>
signLanDownloadUrl({adminBaseUrl, deviceToken, storageKey}): Promise<{signedURL, ...}>
fetchLanEvents({baseUrl, since, eventId, signal, timeoutMs}): Promise<LanEventsResponse>
registerPairedDeviceOnAdminLocal({device_id, event_id, ...}): Promise<void>
