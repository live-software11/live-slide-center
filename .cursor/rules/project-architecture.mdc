src/features/{nome}/
Ōö£ŌöĆŌöĆ components/     # Componenti UI del modulo
Ōö£ŌöĆŌöĆ hooks/          # useMyData.ts, useMyActions.ts
Ōö£ŌöĆŌöĆ lib/            # Logica pura, utilities
Ōö£ŌöĆŌöĆ types.ts        # Tipi TypeScript del modulo
Ōö£ŌöĆŌöĆ repository.ts   # CRUD Supabase (query, insert, update, delete)
