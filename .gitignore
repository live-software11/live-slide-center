# =============================================================================
# Live SLIDE CENTER — .gitignore
# Monorepo: apps/web (cloud) + apps/desktop|agent|room-agent (Tauri 2 / Rust)
# + packages/* (shared, ui)
# =============================================================================

# --- Node / pnpm ---
node_modules
**/node_modules/
.pnpm-store/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Build output: web (Vite) ---
dist
**/dist/
**/dist-desktop/
.turbo
**/.turbo/
**/.tsbuildinfo
*.tsbuildinfo

# --- Build output: shared / ui ---
packages/shared/dist
packages/ui/dist

# --- Build output: Rust / Cargo / Tauri (universale: copre desktop, agent, room-agent, futuri) ---
**/target/
**/Cargo.lock.bak
apps/desktop/src-tauri/gen/
apps/agent/src-tauri/gen/
apps/room-agent/src-tauri/gen/

# --- tsc -b emit (non servono nel repo: Vite bundla i .ts direttamente) ---
apps/web/src/**/*.js
apps/web/src/**/*.d.ts
!apps/web/src/vite-env.d.ts
apps/web/*.js
apps/web/*.d.ts

# --- Env / secrets ---
.env
.env.local
.env.*.local
*.local

# --- IDE / editor ---
.vscode/settings.json
!.vscode/extensions.json
.idea/
.codium/

# --- Cursor / AI assistants ---
.claude/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Test ---
coverage
**/coverage/
playwright-report/
test-results/
e2e-results/

# --- Supabase local ---
supabase/.branches
supabase/.temp

# --- Vercel CLI link/cache ---
.vercel
.vercel-deploy.log
.vercel-smoke.log

# --- Sprint 3: artefatti di distribuzione (NSIS installer + portable ZIP) ---
release/

# --- Sprint 5: manuali operatore PDF generati da pandoc (sorgenti MD versionati) ---
docs/Manuali/pdf/

# --- Cartelle / file temporanei build/scripting locale ---
.tmp/
.tmp-*.txt
.commit-msg.txt
.commit-msg-*.txt
COMMIT_MSG_TMP.txt
*.bak
*.swp

# --- Tauri sidecar binaries (se esistono) ---
**/sidecar/*.exe
**/sidecar/*.dylib
**/sidecar/*.so
