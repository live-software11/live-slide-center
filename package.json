{
  "name": "live-slide-center",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "dev:desktop": "pnpm --filter @slidecenter/desktop dev",
    "build": "turbo run build",
    "build:desktop": "pnpm --filter @slidecenter/web build:desktop && pnpm --filter @slidecenter/desktop build:tauri",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup:supabase-mcp": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./scripts/Setup-Supabase-MCP.ps1\"",
    "verify:supabase-mcp": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./scripts/Verifica-Supabase-MCP.ps1\""
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6"
  }
}
