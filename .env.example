# =============================================================================
# Live SLIDE CENTER — Variabili ambiente
# Copia questo file in `.env` nella ROOT del monorepo (stessa cartella di `pnpm-workspace.yaml`).
# NON committare `.env`. `apps/web` (Vite) carica le variabili da quella root (`envDir` in vite.config).
# EN: Place `.env` at monorepo root (same folder as `pnpm-workspace.yaml`); Vite reads env from there.
# =============================================================================
#
# ── COSA SERVE DOVE ──────────────────────────────────────────────────────────
#  VITE_*                          → bundle frontend (lette da Vite, esposte al browser)
#  SUPABASE_PROJECT_REF, ACCESS    → script `pnpm db:*` e CLI Supabase locale (NON nel bundle)
#  SLIDECENTER_LICENSING_HMAC_*    → SOLO Edge Function `licensing-sync` (Supabase secrets)
#  EMAIL_SEND_INTERNAL_SECRET      → SOLO Edge Function `email-send` + cron esterno
#  RESEND_API_KEY                  → SOLO Edge Function `email-send` (Supabase secrets)
#  HMAC condiviso con Live WORKS APP → Cloud Function billing-license-push (Firebase)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1) FRONTEND — Vite / Vercel build (esposte al browser)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase: URL + chiave anonima del progetto (Settings → API).
# Vercel: aggiungere a Production + Preview + Development.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# App identity
VITE_APP_NAME="Live SLIDE CENTER"
VITE_APP_VERSION=0.0.1

# Billing (Lemon Squeezy / Live WORKS APP — Fase 11)
# Checkout e portale sono ospitati su Lemon Squeezy (gestione centralizzata via Live WORKS APP).
# Lasciare vuote finche' il negozio non e' collegato: la pagina /billing mostra comunque piano e quote.
# EN: Optional hosted checkout URLs; empty = upgrade buttons hidden until the Live WORKS store is wired.
# VITE_LEMONSQUEEZY_CHECKOUT_STARTER_URL=
# VITE_LEMONSQUEEZY_CHECKOUT_PRO_URL=
# VITE_LEMONSQUEEZY_CUSTOMER_PORTAL_URL=
# VITE_LIVE_WORKS_APP_URL=https://www.liveworksapp.com

# Osservabilita / hardening (Fase 14)
# Sentry React (progetto live.software11). Vuoto = SDK non inizializzato.
# EN: Optional Sentry DSN; when empty the SDK is not initialized.
# VITE_SENTRY_DSN=

# Desktop offline LAN (Sprint J / Fase 3)
# Backend mode: `cloud` (default Vercel/Supabase) oppure `desktop` (Tauri 2 + server Rust locale, Sprint K).
# La build `pnpm --filter @slidecenter/web build:desktop` forza automaticamente `desktop` via Vite.
# EN: Backend mode for the SPA. `cloud` is default; `desktop` switches to the local Rust server (Sprint K).
# VITE_BACKEND_MODE=cloud
# Override URL del backend desktop (default `http://127.0.0.1:7300`). Utile in dev su porte alternative.
# EN: Optional override of the desktop backend URL.
# VITE_DESKTOP_BACKEND_URL=http://127.0.0.1:7300


# ─────────────────────────────────────────────────────────────────────────────
# 2) SUPABASE CLI — script `pnpm db:types`, `pnpm db:push`, `pnpm fn:deploy`
#    (NON committare; NON entra nel bundle frontend)
# ─────────────────────────────────────────────────────────────────────────────

# Project ref alfanumerico, lo trovi su Settings → General → Reference ID.
# SUPABASE_PROJECT_REF=abcdefghijklmnopqrst
# Personal Access Token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DB password (per `supabase db push` non interattivo)
# SUPABASE_DB_PASSWORD=xxxxx


# ─────────────────────────────────────────────────────────────────────────────
# 3) SUPABASE EDGE FUNCTIONS — secrets (impostare via Supabase Dashboard
#    Project → Edge Functions → Manage secrets, NON in .env locale)
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: questi NON vanno mai in `.env` qui sotto. Sono solo documentati
# per riferimento. Settarli via:
#   supabase secrets set --project-ref $REF KEY=value
# oppure dalla UI Supabase.
#
#  SLIDECENTER_LICENSING_HMAC_SECRET   ≥ 32 char  (HMAC condiviso con Live WORKS APP)
#  EMAIL_SEND_INTERNAL_SECRET          ≥ 32 char  (cron job → email-send)
#  RESEND_API_KEY                       Resend API key per invii transazionali
#  RESEND_FROM_ADDRESS                 "noreply@your-domain.tld"
#  PUBLIC_APP_URL                       URL produzione (es. https://app.liveslidecenter.com)
#                                       usato in template email + redirect OAuth
#
# Le `SUPABASE_URL` e `SUPABASE_SERVICE_ROLE_KEY` sono iniettate AUTOMATICAMENTE
# da Supabase nel runtime delle Edge Functions: NON vanno settate manualmente.


# ─────────────────────────────────────────────────────────────────────────────
# 4) VERCEL — gestione env vars
# ─────────────────────────────────────────────────────────────────────────────
# Tutte le `VITE_*` sopra DEVONO essere settate in Vercel:
#   Project Settings → Environment Variables → aggiungi per Production / Preview / Development.
# Per pull rapido in locale: `pnpm vercel:env:pull` (genera .env.local).
# Per deploy manuale di prova: `pnpm vercel:deploy:prod`.
